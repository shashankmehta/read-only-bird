TWITTER_AUTH_TOKEN=       # X/Twitter auth_token cookie (main account)
TWITTER_CT0=              # X/Twitter ct0 cookie (main account)
SECONDARY_AUTH_TOKEN=     # X/Twitter auth_token cookie (secondary account, for generic reads)
SECONDARY_CT0=            # X/Twitter ct0 cookie (secondary account, for generic reads)
DASHBOARD_PASSWORD=       # Password for dashboard basic auth (leave empty to disable)
PORT=3000                 # Server port (default 3000)
